    "three": "^0.171.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
